    {
      "name": "get offer list",
      "description": "get offer list data",
      "priority": "p2",
      "base_url": "operation",
      "tags": ["regression"],
      "method": "GET",
	  "url": "/prod-api/offer/getList",
      "require_login": true,
      "params": {
        "pageNum": 1,
		"pageSize": 100
      },
      "assertions": [
        {
          "type": "status_code",
          "expected": 200
        },
        {
          "type": "eq",
          "path": "body.code",
          "expected": 200
        },
        {
          "type": "array_contains",
          "path": "body.rows[*].offerId",
          "expected": "${$extract.offerId}"
        }
      ],
      "cleanup": {
        "enable": false,
        "type": "sql",
        "sql": {
          "connection": "default",
          "statement": "delete from offer where offer_id = ${$extract.offerId}"
        }
      }
    }
